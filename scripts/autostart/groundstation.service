[Unit]
Description=DAEDALUS Ground Station Backend
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/DDL-JS
ExecStart=/home/pi/DDL-JS/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
